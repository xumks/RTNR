<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <include
        android:id="@+id/top"
        layout="@layout/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/tip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/top"
        android:layout_marginLeft="@dimen/margin_"
        android:layout_marginRight="@dimen/margin_"
        android:textColor="@color/black"
        android:textSize="@dimen/txt_size"
        android:visibility="gone" />


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tip"
        android:layout_marginTop="20dp">

    </ScrollView>

    <Button
        android:id="@+id/iatBtn"
        android:layout_width="match_parent"
        android:layout_height="105dp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="160dp"
        android:layout_marginRight="10dp"
        android:backgroundTint="#99CC99"
        android:text="连续语音识别"
        android:textColor="@color/black"
        android:textSize="@dimen/btn_size" />

    <Button
        android:id="@+id/asrBtn"
        android:layout_width="match_parent"
        android:layout_height="104dp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginRight="10dp"
        android:backgroundTint="#99CC99"
        android:text="命令词识别"
        android:textColor="@color/black"
        android:textSize="@dimen/btn_size" />

    <Button
        android:id="@+id/btn_bird_recognize"
        android:layout_width="match_parent"
        android:layout_height="104dp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginRight="10dp"
        android:backgroundTint="#FFCC80"
        android:text="鸟鸣识别"
        android:textColor="@color/black"
        android:textSize="@dimen/btn_size" />

    <Button
        android:id="@+id/birdBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="鸟叫识别（联网版）" />

</LinearLayout>