#BNF+IAT 1.0 UTF-8;
!grammar call;
!slot <role>;
!slot <action>;
!slot <injectionAct>;
!slot <enquire>;
!slot <term>;
!slot <drugs>;
!slot <value>;
!slot <unit>;
!start <commands>;
<commands>:<currency>|<injection>|<enquire>|<prepare>;
